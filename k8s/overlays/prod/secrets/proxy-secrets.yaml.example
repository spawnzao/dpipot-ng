---
# Exemplo de secrets para odpipot-proxy em produção
# Copie este arquivo para proxy-secrets.yaml e preencha os valores reais
apiVersion: v1
kind: Secret
metadata:
  name: proxy-secrets
  namespace: dpipot
type: Opaque
stringData:
  # Token para autenticação no GHCR (GitHub Container Registry)
  # GHCR_TOKEN: "ghp_xxxxxxxxxxxx"
  
  # Chave API para serviços externos (se necessário)
  # API_KEY: "sk-xxxxxxxxxxxx"